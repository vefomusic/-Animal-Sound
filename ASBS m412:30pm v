function generateDemoBuffer(cat, dur) {
  const sr = audioCtx.sampleRate;
  const len = Math.ceil(sr * dur);
  const buf = audioCtx.createBuffer(1, len, sr);
  const ch = buf.getChannelData(0);

  if (cat === 'kick') {
    for (let i = 0; i < len; i++) {
      const t = i / sr;
      const freq = 80 * Math.exp(-t * 30);
      ch[i] = Math.sin(2 * Math.PI * freq * t) * Math.exp(-t * 8);
    }
  } else if (cat === 'snare') {
    for (let i = 0; i < len; i++) {
      const t = i / sr;
      ch[i] = ((Math.random() * 2 - 1) * 0.5 + Math.sin(2*Math.PI*200*t)*0.3) * Math.exp(-t*15);
    }
  } else if (cat === 'perc') {
    for (let i = 0; i < len; i++) {
      const t = i / sr;
      ch[i] = (Math.random()*2-1) * 0.3 * Math.exp(-t*30);
    }
  } else if (cat === 'vocal') {
    for (let i = 0; i < len; i++) {
      const t = i / sr;
      const env = Math.min(t*4, 1) * Math.exp(-t*0.5);
      ch[i] = (Math.sin(2*Math.PI*440*t) + Math.sin(2*Math.PI*880*t)*0.3 + Math.sin(2*Math.PI*1320*t)*0.1) * env * 0.4;
    }
  } else {
    for (let i = 0; i < len; i++) {
      const t = i / sr;
      const env = Math.min(t*2, 1) * Math.exp(-t*0.3);
      ch[i] = (Math.sin(2*Math.PI*261.63*t) + Math.sin(2*Math.PI*329.63*t)*0.5) * env * 0.4;
    }
  }
  return buf;
}

function clearAll() {
  stopPlayback();
  patterns.forEach(p => p.el.remove());
  patterns = [];
  showToast('🗑 Timeline cleared');
}

// ─── EXPORT ──────────────────────────────────────────────────────────
async function exportAudio() {
  initAudio();
  if (patterns.length === 0) { showToast('⚠️ No patterns to export'); return; }
  showToast('⏳ Rendering... this may take a moment');

  const totalDur = Math.max(...patterns.map(p => p.beatPos * 60/bpm + p.sample.buffer.duration)) + adsr.r + 0.5;
  const offCtx = new OfflineAudioContext(2, Math.ceil(totalDur * audioCtx.sampleRate), audioCtx.sampleRate);

  const gain = offCtx.createGain();
  gain.gain.value = masterGain.gain.value;
  gain.connect(offCtx.destination);

  patterns.forEach(p => {
    if (mutedTracks.has(p.trackIdx)) return;
    const src = offCtx.createBufferSource();
    src.buffer = p.sample.buffer;
    src.connect(gain);
    src.start(p.beatPos * 60 / bpm);
  });

  const rendered = await offCtx.startRendering();
  const wav = bufferToWave(rendered);
  const url = URL.createObjectURL(new Blob([wav], { type: 'audio/wav' }));
  const a = document.createElement('a');
  a.href = url;
  a.download = 'animal-sound-bridge-mix.wav';
  a.click();
  showToast('✅ Exported as WAV!');
}

function bufferToWave(buf) {
  const numCh = buf.numberOfChannels;
  const len = buf.length * numCh * 2 + 44;
  const ab = new ArrayBuffer(len);
  const view = new DataView(ab);
  const writeStr = (v, o, s) => { for (let i=0;i<s.length;i++) v.setUint8(o+i, s.charCodeAt(i)); };
  writeStr(view, 0, 'RIFF');
  view.setUint32(4, len-8, true);
  writeStr(view, 8, 'WAVE');
  writeStr(view, 12, 'fmt ');
  view.setUint32(16, 16, true);
  view.setUint16(20, 1, true);
  view.setUint16(22, numCh, true);
  view.setUint32(24, buf.sampleRate, true);
  view.setUint32(28, buf.sampleRate * numCh * 2, true);
  view.setUint16(32, numCh*2, true);
  view.setUint16(34, 16, true);
  writeStr(view, 36, 'data');
  view.setUint32(40, buf.length * numCh * 2, true);
  let offset = 44;
  for (let i = 0; i < buf.length; i++) {
    for (let c = 0; c < numCh; c++) {
      const s = Math.max(-1, Math.min(1, buf.getChannelData(c)[i]));
      view.setInt16(offset, s < 0 ? s*0x8000 : s*0x7FFF, true);
      offset += 2;
    }
  }
  return ab;
}

// ─── EFFECTS ─────────────────────────────────────────────────────────
function updateMasterVol(v) {
  document.getElementById('masterVolVal').textContent = v + '%';
  if (masterGain) masterGain.gain.value = v / 100;
}

function updateFilter(param, v) {
  if (param === 'freq') {
    document.getElementById('filterFreqVal').textContent = v > 999 ? (v/1000).toFixed(1)+'k' : v+'Hz';
    if (filterNode) filterNode.frequency.value = parseFloat(v);
  } else if (param === 'res') {
    document.getElementById('filterResVal').textContent = parseFloat(v).toFixed(1);
    if (filterNode) filterNode.Q.value = parseFloat(v);
  } else if (param === 'gain') {
    document.getElementById('filterGainVal').textContent = v+'dB';
  }
}

function updateEnv(key, v) {
  adsr[key] = parseFloat(v);
  const labels = {
    a: ['atkVal', ms => ms < 0.1 ? Math.round(ms*1000)+'ms' : ms.toFixed(2)+'s'],
    d: ['decVal', ms => ms < 0.1 ? Math.round(ms*1000)+'ms' : ms.toFixed(2)+'s'],
    s: ['susVal', v => Math.round(v*100)+'%'],
    r: ['relVal', ms => ms < 0.1 ? Math.round(ms*1000)+'ms' : ms.toFixed(2)+'s'],
  };
  const [id, fmt] = labels[key];
  document.getElementById(id).textContent = fmt(parseFloat(v));
  drawEnvelope();
}

function drawEnvelope() {
  const canvas = document.getElementById('envCanvas');
  if (!canvas) return;
  canvas.width = canvas.offsetWidth || 240;
  const ctx = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  ctx.clearRect(0, 0, w, h);

  const { a, d, s, r } = adsr;
  const total = Math.max(a + d + 0.3 + r, 0.5);
  const toX = t => (t/total) * (w-10) + 5;
  const toY = v => h - 6 - v*(h-12);

  ctx.strokeStyle = 'rgba(93,255,143,0.8)';
  ctx.lineWidth = 2;
  ctx.shadowColor = 'var(--accent)';
  ctx.shadowBlur = 4;
  ctx.beginPath();
  ctx.moveTo(toX(0), toY(0));
  ctx.lineTo(toX(a), toY(1));
  ctx.lineTo(toX(a+d), toY(s));
  ctx.lineTo(toX(a+d+0.3), toY(s));
  ctx.lineTo(toX(a+d+0.3+r), toY(0));
  ctx.stroke();

  ctx.fillStyle = 'rgba(93,255,143,0.07)';
  ctx.fill();
}

function updateReverb(param, v) {
  if (param === 'size') {
    document.getElementById('rvbSizeVal').textContent = v + '%';
    if (audioCtx) createImpulse(parseFloat(v)/100*4 + 0.1, 1.5);
  } else {
    document.getElementById('rvbMixVal').textContent = v + '%';
    if (reverbGain) reverbGain.gain.value = parseFloat(v)/100;
    if (dryGain) dryGain.gain.value = 1 - parseFloat(v)/100*0.5;
  }
}

function updateLfo(param, v) {
  if (param === 'rate') {
    document.getElementById('lfoRateVal').textContent = parseFloat(v).toFixed(1) + 'Hz';
  } else {
    document.getElementById('lfoDepthVal').textContent = v + '%';
  }
}

