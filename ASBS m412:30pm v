<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Animal Sound Bridge Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0d0d0f;
  --bg2: #141417;
  --bg3: #1c1c21;
  --bg4: #242429;
  --border: #2a2a32;
  --border2: #353540;
  --accent: #5dff8f;
  --accent2: #3de070;
  --yellow: #f9d342;
  --blue: #4d9fff;
  --purple: #a855f7;
  --red: #ff5f5f;
  --text: #e8e8f0;
  --text2: #9090a8;
  --text3: #5a5a70;
  --track1: #5dff8f;
  --track2: #4d9fff;
  --track3: #f9d342;
  --track4: #a855f7;
  --track5: #ff7849;
  --playhead: #ff4466;
  --px-per-beat: 80px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* HEADER */
.header {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 12px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-icon {
  width: 34px;
  height: 34px;
  background: linear-gradient(135deg, var(--accent), var(--blue));
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
}

.logo-text {
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.5px;
}

.logo-sub {
  font-size: 10px;
  color: var(--text3);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.header-center {
  display: flex;
  align-items: center;
  gap: 8px;
}

/* TRANSPORT */
.transport {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 6px 10px;
}

.tbtn {
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  transition: all 0.15s;
  background: var(--bg4);
  color: var(--text2);
}

.tbtn:hover { background: var(--border2); color: var(--text); }
.tbtn.play-btn { background: var(--accent); color: #000; }
.tbtn.play-btn:hover { background: var(--accent2); }
.tbtn.play-btn.playing { background: var(--yellow); }
.tbtn.stop-btn:hover { background: var(--red); color: #fff; }
.tbtn.rec-btn { color: var(--red); }
.tbtn.rec-btn.recording { background: var(--red); color: #fff; animation: recpulse 1s infinite; }

@keyframes recpulse { 0%,100%{opacity:1} 50%{opacity:.5} }

.divider { width: 1px; height: 24px; background: var(--border); margin: 0 4px; }

.timecode {
  font-family: 'Space Mono', monospace;
  font-size: 15px;
  font-weight: 700;
  color: var(--accent);
  background: var(--bg);
  border: 1px solid var(--border);
  padding: 6px 14px;
  border-radius: 7px;
  letter-spacing: 1px;
  min-width: 110px;
  text-align: center;
}

.bpm-ctrl {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--bg4);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 5px 10px;
}

.bpm-label { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; }

.bpm-input {
  width: 50px;
  background: none;
  border: none;
  outline: none;
  font-family: 'Space Mono', monospace;
  font-size: 16px;
  font-weight: 700;
  color: var(--yellow);
  text-align: center;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.hbtn {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text2);
  padding: 7px 14px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
  transition: all 0.15s;
}

.hbtn:hover { border-color: var(--border2); color: var(--text); }
.hbtn.primary { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 700; }
.hbtn.primary:hover { background: var(--accent2); }

/* MAIN */
.main {
  flex: 1;
  display: grid;
  grid-template-columns: 240px 1fr 280px;
  overflow: hidden;
}

/* SIDEBAR - SAMPLE BROWSER */
.sidebar {
  background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sidebar-header {
  padding: 14px 16px 10px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.sidebar-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ai-tag {
  background: linear-gradient(135deg, #6366f1, #a855f7);
  color: white;
  font-size: 9px;
  padding: 2px 7px;
  border-radius: 20px;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.upload-zone {
  margin: 10px 16px 14px;
  border: 2px dashed var(--border2);
  border-radius: 10px;
  padding: 14px;
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--bg3);
  flex-shrink: 0;
}

.upload-zone:hover, .upload-zone.dragover {
  border-color: var(--accent);
  background: rgba(93, 255, 143, 0.05);
}

.upload-icon { font-size: 22px; margin-bottom: 5px; }

.upload-text {
  font-size: 11px;
  color: var(--text2);
  font-weight: 500;
}

.upload-sub {
  font-size: 10px;
  color: var(--text3);
  margin-top: 2px;
}

#fileInput { display: none; }

.category-group { padding: 0 16px; margin-bottom: 6px; flex-shrink: 0; }

.cat-label {
  font-size: 10px;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 700;
  padding: 8px 0 6px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.cat-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.samples-list {
  flex: 1;
  overflow-y: auto;
  padding: 0 16px 16px;
}

.samples-list::-webkit-scrollbar { width: 4px; }
.samples-list::-webkit-scrollbar-track { background: transparent; }
.samples-list::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

.sample-item {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 9px 11px;
  margin-bottom: 5px;
  cursor: grab;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  gap: 9px;
  user-select: none;
}

.sample-item:hover {
  border-color: var(--border2);
  background: var(--bg4);
  transform: translateX(2px);
}

.sample-item:active { cursor: grabbing; }

.sample-item.playing { border-color: var(--accent); background: rgba(93,255,143,0.07); }

.samp-emoji { font-size: 20px; line-height: 1; }

.samp-info { flex: 1; min-width: 0; }

.samp-name {
  font-size: 12px;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.samp-meta {
  font-size: 10px;
  color: var(--text3);
  margin-top: 1px;
}

.samp-cat {
  font-size: 9px;
  padding: 2px 7px;
  border-radius: 20px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  flex-shrink: 0;
}

.cat-kick { background: rgba(255,95,95,0.2); color: #ff5f5f; }
.cat-snare { background: rgba(249,211,66,0.2); color: #f9d342; }
.cat-vocal { background: rgba(93,255,143,0.2); color: #5dff8f; }
.cat-perc { background: rgba(168,85,247,0.2); color: #a855f7; }
.cat-inst { background: rgba(77,159,255,0.2); color: #4d9fff; }

/* TIMELINE */
.timeline-area {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg);
  position: relative;
}

.timeline-toolbar {
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  padding: 8px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.quant-group {
  display: flex;
  align-items: center;
  gap: 5px;
}

.quant-label { font-size: 10px; color: var(--text3); text-transform: uppercase; letter-spacing: 1px; margin-right: 4px; }

.qbtn {
  background: var(--bg3);
  border: 1px solid var(--border);
  color: var(--text3);
  padding: 4px 10px;
  border-radius: 5px;
  cursor: pointer;
  font-size: 11px;
  font-weight: 600;
  transition: all 0.15s;
}

.qbtn:hover { border-color: var(--border2); color: var(--text2); }
.qbtn.active { background: var(--accent); border-color: var(--accent); color: #000; }

.timeline-hint {
  font-size: 11px;
  color: var(--text3);
}

/* RULER + TRACKS SCROLL AREA */
.timeline-scroll {
  flex: 1;
  overflow: auto;
  position: relative;
}

.timeline-scroll::-webkit-scrollbar { height: 6px; width: 6px; }
.timeline-scroll::-webkit-scrollbar-track { background: var(--bg2); }
.timeline-scroll::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

.timeline-inner {
  min-width: 2000px;
  position: relative;
}

/* RULER */
.ruler {
  height: 28px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  cursor: pointer;
  margin-left: 110px;
}

.ruler-beat {
  width: var(--px-per-beat);
  flex-shrink: 0;
  border-right: 1px solid var(--border);
  display: flex;
  align-items: center;
  padding: 0 5px;
  position: relative;
}

.ruler-beat-num {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  font-weight: 700;
  color: var(--text3);
}

.ruler-beat.bar-start .ruler-beat-num { color: var(--text2); }

.ruler-sub {
  position: absolute;
  top: 0;
  height: 8px;
  width: 1px;
  background: var(--border);
}

/* PLAYHEAD */
.playhead {
  position: absolute;
  top: 0;
  width: 2px;
  background: var(--playhead);
  pointer-events: none;
  z-index: 20;
  margin-left: 110px;
  box-shadow: 0 0 8px rgba(255,68,102,0.6);
  transition: none;
}

.playhead::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 10px;
  height: 10px;
  background: var(--playhead);
  clip-path: polygon(50% 100%, 0 0, 100% 0);
}

/* TRACKS */
.tracks-wrapper {
  position: relative;
}

.track-row {
  height: 72px;
  border-bottom: 1px solid var(--border);
  display: flex;
  position: relative;
}

.track-label {
  width: 110px;
  flex-shrink: 0;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  padding: 8px 10px;
  display: flex;
  align-items: center;
  gap: 8px;
  position: sticky;
  left: 0;
  z-index: 5;
}

.track-color-bar {
  width: 3px;
  height: 36px;
  border-radius: 2px;
  flex-shrink: 0;
}

.track-info { flex: 1; min-width: 0; }

.track-name {
  font-size: 11px;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-type {
  font-size: 9px;
  color: var(--text3);
  margin-top: 2px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.track-mute {
  width: 20px;
  height: 20px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 4px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  color: var(--text3);
  transition: all 0.15s;
  flex-shrink: 0;
}

.track-mute:hover { border-color: var(--border2); }
.track-mute.muted { background: var(--red); border-color: var(--red); color: #fff; }

.track-content {
  flex: 1;
  position: relative;
  background-image: repeating-linear-gradient(
    90deg,
    transparent,
    transparent calc(var(--px-per-beat) - 1px),
    var(--border) calc(var(--px-per-beat) - 1px),
    var(--border) var(--px-per-beat)
  );
  min-width: 1890px;
}

.track-content.drag-over {
  background-color: rgba(93,255,143,0.04);
}

/* PATTERN BLOCKS */
.pattern-block {
  position: absolute;
  height: 52px;
  top: 10px;
  border-radius: 6px;
  padding: 6px 10px;
  cursor: move;
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  overflow: hidden;
  user-select: none;
  border: 1px solid rgba(255,255,255,0.1);
  transition: box-shadow 0.15s, transform 0.1s;
  min-width: 30px;
}

.pattern-block:hover {
  transform: translateY(-1px);
  border-color: rgba(255,255,255,0.25);
}

.pattern-block.selected {
  border-color: rgba(255,255,255,0.5);
  box-shadow: 0 0 0 2px rgba(255,255,255,0.15);
}

.pattern-block.playing-now {
  box-shadow: 0 0 16px rgba(255,255,255,0.3);
}

.pat-emoji { font-size: 16px; flex-shrink: 0; }
.pat-name { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.pat-waveform {
  position: absolute;
  bottom: 4px;
  left: 0;
  right: 0;
  height: 14px;
  opacity: 0.4;
}

.pat-remove {
  position: absolute;
  top: 3px;
  right: 4px;
  width: 14px;
  height: 14px;
  background: rgba(0,0,0,0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 8px;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.15s;
  color: #fff;
  font-weight: 900;
  line-height: 1;
  border: none;
}

.pattern-block:hover .pat-remove { opacity: 1; }

/* DEVICE RACK */
.rack {
  background: var(--bg2);
  border-left: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
}

.rack::-webkit-scrollbar { width: 4px; }
.rack::-webkit-scrollbar-track { background: transparent; }
.rack::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

.rack-section {
  border-bottom: 1px solid var(--border);
}

.rack-header {
  padding: 11px 15px;
  background: var(--bg3);
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  transition: background 0.15s;
}

.rack-header:hover { background: var(--bg4); }

.rack-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--text2);
  text-transform: uppercase;
  letter-spacing: 1px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.rack-icon { font-size: 13px; }

.rack-toggle {
  font-size: 10px;
  color: var(--text3);
  transition: transform 0.2s;
}

.rack-body {
  padding: 14px 15px;
  display: block;
}

.rack-body.collapsed { display: none; }

/* SLIDERS */
.ctrl-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.ctrl-lbl {
  font-size: 10px;
  color: var(--text3);
  font-weight: 600;
  width: 52px;
  flex-shrink: 0;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.ctrl-slider {
  flex: 1;
  -webkit-appearance: none;
  height: 4px;
  background: var(--bg4);
  border-radius: 2px;
  outline: none;
  border: 1px solid var(--border2);
}

.ctrl-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  cursor: pointer;
  box-shadow: 0 0 6px rgba(93,255,143,0.4);
  background: var(--accent);
}

.ctrl-slider::-moz-range-thumb {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  cursor: pointer;
  border: none;
  background: var(--accent);
}

.ctrl-val {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  color: var(--accent);
  font-weight: 700;
  width: 38px;
  text-align: right;
  flex-shrink: 0;
}

/* Master Vol */
.master-vol {
  padding: 14px 15px;
  border-bottom: 1px solid var(--border);
}

.mvol-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 10px;
  display: flex;
  justify-content: space-between;
}

.mvol-val {
  font-family: 'Space Mono', monospace;
  color: var(--accent);
}

/* VU Meters */
.vu-meters {
  display: flex;
  gap: 4px;
  height: 50px;
  align-items: flex-end;
  margin-top: 10px;
}

.vu-bar-wrap {
  flex: 1;
  height: 100%;
  background: var(--bg4);
  border-radius: 2px;
  overflow: hidden;
  display: flex;
  flex-direction: column-reverse;
}

.vu-bar {
  width: 100%;
  background: linear-gradient(to top, var(--accent), var(--yellow) 70%, var(--red));
  border-radius: 2px;
  transition: height 0.05s;
  height: 0%;
}

/* Envelope SVG canvas */
.env-canvas {
  width: 100%;
  height: 70px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  margin-bottom: 12px;
  display: block;
}

/* TOAST */
.toast {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 10px;
  padding: 10px 20px;
  font-size: 13px;
  color: var(--text);
  font-weight: 500;
  opacity: 0;
  transition: all 0.3s;
  z-index: 1000;
  pointer-events: none;
  white-space: nowrap;
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* EMPTY STATE */
.empty-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  pointer-events: none;
  opacity: 0.35;
}

.empty-icon { font-size: 40px; margin-bottom: 8px; }
.empty-text { font-size: 13px; color: var(--text3); font-weight: 500; }
.empty-sub { font-size: 11px; color: var(--text3); margin-top: 4px; }

/* AI Classify Badge */
.classify-anim {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(13,13,15,0.95);
  border: 1px solid var(--border2);
  border-radius: 16px;
  padding: 24px 36px;
  text-align: center;
  z-index: 500;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.classify-anim.show { opacity: 1; pointer-events: all; }

.classify-spinner {
  width: 36px;
  height: 36px;
  border: 3px solid var(--border2);
  border-top-color: var(--purple);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 10px;
}

@keyframes spin { to { transform: rotate(360deg); } }

.classify-text { font-size: 13px; color: var(--text); font-weight: 600; }
.classify-sub { font-size: 11px; color: var(--text3); margin-top: 4px; }
</style>
</head>
<body>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- AI CLASSIFY OVERLAY -->
<div class="classify-anim" id="classifyAnim">
  <div class="classify-spinner"></div>
  <div class="classify-text">AI Classifying Sound</div>
  <div class="classify-sub" id="classifySub">Analyzing frequency spectrum...</div>
</div>

<!-- HEADER -->
<div class="header">
  <div class="logo">
    <div class="logo-icon">🐾</div>
    <div>
      <div class="logo-text">Animal Sound Bridge</div>
      <div class="logo-sub">Mini DAW • AI Enhanced</div>
    </div>
  </div>

  <div class="header-center">
    <div class="transport">
      <button class="tbtn stop-btn" id="stopBtn" onclick="stopPlayback()" title="Stop (Space)">⏹</button>
      <button class="tbtn play-btn" id="playBtn" onclick="togglePlay()" title="Play/Pause (Space)">▶</button>
      <button class="tbtn rec-btn" id="recBtn" onclick="toggleRecord()" title="Record">⏺</button>
      <div class="divider"></div>
      <div class="bpm-ctrl">
