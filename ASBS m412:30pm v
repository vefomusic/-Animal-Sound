<script>
// ─── STATE ──────────────────────────────────────────────────────────
let audioCtx = null;
let masterGain, filterNode, reverbNode, reverbGain, dryGain, analyser;
let isPlaying = false, isRecording = false;
let playStartTime = 0;      // audioCtx time when play was pressed
let playheadBeat = 0;       // beat position when play was pressed (for resume)
let animFrame = null;
let patterns = [];          // { id, trackIdx, beatPos, duration, sample, el }
let loadedSamples = {};     // name → { buffer, category, name, emoji }
let scheduledSources = [];
let snapValue = 1;          // beats
let bpm = 120;
let totalBeats = 32;
let pxPerBeat = 80;
let mutedTracks = new Set();

let adsr = { a: 0.01, d: 0.1, s: 0.8, r: 0.3 };
let patternIdCounter = 0;

const TRACK_COLORS = ['var(--track1)','var(--track2)','var(--track3)','var(--track4)','var(--track5)'];
const TRACK_DEFS = [
  { name: 'Kick', type: 'Drums', color: 'var(--track1)', cats: ['kick'] },
  { name: 'Snare', type: 'Drums', color: 'var(--track2)', cats: ['snare'] },
  { name: 'Vocals', type: 'Melodic', color: 'var(--track3)', cats: ['vocal'] },
  { name: 'Percussion', type: 'Rhythm', color: 'var(--track4)', cats: ['perc'] },
  { name: 'Instruments', type: 'Melodic', color: 'var(--track5)', cats: ['inst'] },
];

const CAT_EMOJIS = { kick:'🥁', snare:'🎯', vocal:'🦜', perc:'🐢', inst:'🎸' };
const CAT_LABELS = { kick:'Kick', snare:'Snare', vocal:'Vocal', perc:'Perc', inst:'Inst' };

// ─── INIT ────────────────────────────────────────────────────────────
function initAudio() {
  if (audioCtx) return;
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();

  masterGain = audioCtx.createGain();
  masterGain.gain.value = 0.8;

  analyser = audioCtx.createAnalyser();
  analyser.fftSize = 256;

  filterNode = audioCtx.createBiquadFilter();
  filterNode.type = 'lowpass';
  filterNode.frequency.value = 20000;
  filterNode.Q.value = 1;

  // Reverb
  reverbNode = audioCtx.createConvolver();
  createImpulse(1, 0.2);
  reverbGain = audioCtx.createGain();
  reverbGain.gain.value = 0.15;
  dryGain = audioCtx.createGain();
  dryGain.gain.value = 1;

  masterGain.connect(filterNode);
  filterNode.connect(dryGain);
  filterNode.connect(reverbNode);
  reverbNode.connect(reverbGain);
  dryGain.connect(analyser);
  reverbGain.connect(analyser);
  analyser.connect(audioCtx.destination);
}

function createImpulse(dur, dec) {
  if (!audioCtx) return;
  const sr = audioCtx.sampleRate;
  const len = sr * dur;
  const buf = audioCtx.createBuffer(2, len, sr);
  for (let c = 0; c < 2; c++) {
    const ch = buf.getChannelData(c);
    for (let i = 0; i < len; i++) {
      ch[i] = (Math.random()*2-1) * Math.pow(1 - i/len, dec);
    }
  }
  reverbNode.buffer = buf;
}

// ─── BUILD TIMELINE ──────────────────────────────────────────────────
function buildTimeline() {
  const wrapper = document.getElementById('tracksWrapper');
  wrapper.innerHTML = '';

  TRACK_DEFS.forEach((def, idx) => {
    const row = document.createElement('div');
    row.className = 'track-row';
    row.dataset.track = idx;
    row.innerHTML = `
      <div class="track-label">
        <div class="track-color-bar" style="background:${def.color}"></div>
        <div class="track-info">
          <div class="track-name">${def.name}</div>
          <div class="track-type">${def.type}</div>
        </div>
        <div class="track-mute" onclick="toggleMute(${idx},this)" title="Mute">M</div>
      </div>
      <div class="track-content" id="tc${idx}" data-track="${idx}"></div>
    `;
    wrapper.appendChild(row);
    setupTrackDrop(idx);
  });

  buildRuler();
}

function buildRuler() {
  const ruler = document.getElementById('ruler');
  ruler.innerHTML = '';
  for (let b = 0; b < totalBeats; b++) {
    const el = document.createElement('div');
    el.className = `ruler-beat${b%4===0?' bar-start':''}`;
    el.style.width = pxPerBeat + 'px';
    el.innerHTML = `<span class="ruler-beat-num">${b%4===0 ? Math.floor(b/4)+1 : ''}</span>`;
    // Sub-ticks
    for (let s = 1; s < 4; s++) {
      const tick = document.createElement('div');
      tick.className = 'ruler-sub';
      tick.style.left = (pxPerBeat * s / 4) + 'px';
      tick.style.top = (s===2 ? '0' : '14px');
      el.appendChild(tick);
    }
    ruler.appendChild(el);
  }
}

// ─── DROP ZONES ──────────────────────────────────────────────────────
function setupTrackDrop(idx) {
  const el = document.getElementById('tc'+idx);
  el.addEventListener('dragover', e => { e.preventDefault(); el.classList.add('drag-over'); });
  el.addEventListener('dragleave', () => el.classList.remove('drag-over'));
  el.addEventListener('drop', e => {
    e.preventDefault();
    el.classList.remove('drag-over');
    const name = e.dataTransfer.getData('sampleName');
    const sample = loadedSamples[name];
    if (!sample) return;
    const rect = el.getBoundingClientRect();
    let rawBeat = (e.clientX - rect.left) / pxPerBeat;
    const beat = snapValue === 'free' ? rawBeat : Math.round(rawBeat / snapValue) * snapValue;
    addPattern(idx, beat, sample);
  });
}

// ─── PATTERNS ────────────────────────────────────────────────────────
function addPattern(trackIdx, beatPos, sample) {
  const durationBeats = (sample.buffer.duration * bpm / 60) || 1;
  const id = 'p' + (patternIdCounter++);
  const color = TRACK_DEFS[trackIdx].color;

  const el = document.createElement('div');
  el.className = 'pattern-block';
  el.id = id;
  el.style.left = (beatPos * pxPerBeat) + 'px';
  el.style.width = Math.max(30, durationBeats * pxPerBeat) + 'px';
  el.style.background = color;
  el.style.color = trackIdx < 2 ? '#000' : (trackIdx === 2 ? '#000' : '#fff');
  el.innerHTML = `
    <span class="pat-emoji">${sample.emoji}</span>
    <span class="pat-name">${sample.name.substring(0,12)}</span>
    <button class="pat-remove" onclick="removePattern('${id}')">✕</button>
  `;

  // Draw mini waveform
  const wv = document.createElement('canvas');
  wv.className = 'pat-waveform';
  wv.height = 14;
  el.appendChild(wv);
  drawMiniWaveform(wv, sample.buffer, color);

  // Drag to reposition
  makeDraggablePattern(el, id, trackIdx);

  document.getElementById('tc'+trackIdx).appendChild(el);
  patterns.push({ id, trackIdx, beatPos, durationBeats, sample, el });
}

function drawMiniWaveform(canvas, buffer, color) {
  requestAnimationFrame(() => {
    canvas.width = canvas.offsetWidth || 100;
    const ctx = canvas.getContext('2d');
    const data = buffer.getChannelData(0);
    const step = Math.ceil(data.length / canvas.width);
    const h = canvas.height;
    ctx.strokeStyle = color;
    ctx.globalAlpha = 0.6;
    ctx.lineWidth = 1;
    ctx.beginPath();
    for (let x = 0; x < canvas.width; x++) {
      let max = 0;
      for (let j = 0; j < step; j++) max = Math.max(max, Math.abs(data[x*step+j]||0));
      const y = h/2 - max * h/2;
      ctx.moveTo(x, h/2);
      ctx.lineTo(x, y);
    }
    ctx.stroke();
  });
}

function makeDraggablePattern(el, id, trackIdx) {
  let dragging = false, startX, startBeat;
  el.addEventListener('mousedown', e => {
    if (e.target.classList.contains('pat-remove')) return;
    dragging = true;
    startX = e.clientX;
    const p = patterns.find(p => p.id === id);
    startBeat = p ? p.beatPos : 0;
    el.classList.add('selected');
    e.preventDefault();
  });
  document.addEventListener('mousemove', e => {
    if (!dragging) return;
    const dx = e.clientX - startX;
    let newBeat = startBeat + dx / pxPerBeat;
    if (snapValue !== 'free') newBeat = Math.round(newBeat / snapValue) * snapValue;
    newBeat = Math.max(0, newBeat);
    el.style.left = (newBeat * pxPerBeat) + 'px';
    const p = patterns.find(p => p.id === id);
    if (p) p.beatPos = newBeat;
  });
  document.addEventListener('mouseup', () => {
    if (dragging) { dragging = false; el.classList.remove('selected'); }
  });
}

function removePattern(id) {
  const idx = patterns.findIndex(p => p.id === id);
  if (idx !== -1) {
    patterns[idx].el.remove();
    patterns.splice(idx, 1);
  }
}

// ─── PLAYBACK ────────────────────────────────────────────────────────
function togglePlay() {
  initAudio();
  if (audioCtx.state === 'suspended') audioCtx.resume();
  isPlaying ? pausePlayback() : startPlayback();
}

function startPlayback() {
  isPlaying = true;
  playStartTime = audioCtx.currentTime - (playheadBeat * 60 / bpm);
  document.getElementById('playBtn').innerHTML = '⏸';
  document.getElementById('playBtn').classList.add('playing');

  // Schedule all patterns
  scheduledSources.forEach(s => { try { s.stop(); } catch(e){} });
  scheduledSources = [];

  patterns.forEach(p => {
    if (mutedTracks.has(p.trackIdx)) return;
    const startInSeconds = p.beatPos * 60 / bpm;
    const now = audioCtx.currentTime;
    const elapsed = now - playStartTime;
    const offset = elapsed - startInSeconds;
    if (offset >= p.sample.buffer.duration) return; // already passed

    const src = audioCtx.createBufferSource();
    src.buffer = p.sample.buffer;

    // ADSR gain
    const gainNode = audioCtx.createGain();
    const t = now;
    const startAt = playStartTime + startInSeconds;
    const actualStart = Math.max(startAt, now);
    gainNode.gain.setValueAtTime(0, actualStart);
    gainNode.gain.linearRampToValueAtTime(1, actualStart + adsr.a);
    gainNode.gain.linearRampToValueAtTime(adsr.s, actualStart + adsr.a + adsr.d);
    gainNode.gain.setValueAtTime(adsr.s, actualStart + adsr.a + adsr.d);
    const endAt = actualStart + p.sample.buffer.duration - (offset > 0 ? 0 : 0);
    gainNode.gain.linearRampToValueAtTime(0, endAt + adsr.r);

    src.connect(gainNode);
    gainNode.connect(masterGain);

    if (offset < 0) {
      src.start(actualStart, 0);
    } else if (offset < p.sample.buffer.duration) {
      src.start(now, offset);
    }

    scheduledSources.push(src);
  });

  animFrame = requestAnimationFrame(animLoop);
}

function pausePlayback() {
  isPlaying = false;
  playheadBeat = (audioCtx.currentTime - playStartTime) * bpm / 60;
  document.getElementById('playBtn').innerHTML = '▶';
  document.getElementById('playBtn').classList.remove('playing');
  scheduledSources.forEach(s => { try { s.stop(); } catch(e){} });
  scheduledSources = [];
  cancelAnimationFrame(animFrame);
}

function stopPlayback() {
  isPlaying = false;
  playheadBeat = 0;
  document.getElementById('playBtn').innerHTML = '▶';
  document.getElementById('playBtn').classList.remove('playing');
  scheduledSources.forEach(s => { try { s.stop(); } catch(e){} });
  scheduledSources = [];
  cancelAnimationFrame(animFrame);
  updatePlayheadPos(0);
  document.getElementById('timecode').textContent = '0:00.000';
  // un-highlight all patterns
  patterns.forEach(p => p.el.classList.remove('playing-now'));
}

function animLoop() {
  if (!isPlaying) return;
  const elapsed = audioCtx.currentTime - playStartTime;
  const beat = elapsed * bpm / 60;

  updatePlayheadPos(beat);
  updateTimecodeDisplay(elapsed);
  updateVU();
  highlightPlaying(beat);

  // Auto-scroll to keep playhead visible
  const scroll = document.getElementById('timelineScroll');
  const phPx = beat * pxPerBeat;
  const scrollLeft = scroll.scrollLeft;
  const viewW = scroll.clientWidth - 110;
  if (phPx > scrollLeft + viewW * 0.8) {
    scroll.scrollLeft = phPx - viewW * 0.3;
  }

  // Loop or stop
  if (beat >= totalBeats) {
    stopPlayback();
    return;
  }

  animFrame = requestAnimationFrame(animLoop);
}

function updatePlayheadPos(beat) {
  const ph = document.getElementById('playhead');
  ph.style.left = (beat * pxPerBeat + 110) + 'px';

  // Height = ruler + all tracks
  const wrapper = document.getElementById('tracksWrapper');
  ph.style.height = (28 + wrapper.offsetHeight) + 'px';
}

function updateTimecodeDisplay(elapsed) {
  const m = Math.floor(elapsed / 60);
  const s = Math.floor(elapsed % 60);
  const ms = Math.floor((elapsed % 1) * 1000);
  document.getElementById('timecode').textContent =
    `${m}:${s.toString().padStart(2,'0')}.${ms.toString().padStart(3,'0')}`;
}

function highlightPlaying(beat) {
  patterns.forEach(p => {
    const active = beat >= p.beatPos && beat < p.beatPos + p.durationBeats;
    p.el.classList.toggle('playing-now', active);
  });
}

function updateVU() {
  if (!analyser) return;
  const data = new Uint8Array(analyser.frequencyBinCount);
  analyser.getByteFrequencyData(data);
  const numBars = 8;
  const step = Math.floor(data.length / numBars);
  for (let i = 0; i < numBars; i++) {
    let sum = 0;
    for (let j = 0; j < step; j++) sum += data[i*step+j];
    const pct = (sum / step / 255) * 100;
    const bar = document.getElementById('vu'+i);
    if (bar) bar.style.height = pct + '%';
  }
}

// ─── SEEK ────────────────────────────────────────────────────────────
function seekToClick(e) {
  const ruler = document.getElementById('ruler');
  const rect = ruler.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const beat = Math.max(0, x / pxPerBeat);
  playheadBeat = beat;
  updatePlayheadPos(beat);
  if (isPlaying) {
    pausePlayback();
    startPlayback();
  }
}

// ─── SNAP ────────────────────────────────────────────────────────────
function setSnap(btn, val) {
  document.querySelectorAll('.qbtn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  snapValue = val;
}

// ─── MUTE ────────────────────────────────────────────────────────────
function toggleMute(idx, el) {
  if (mutedTracks.has(idx)) {
    mutedTracks.delete(idx);
    el.classList.remove('muted');
  } else {
    mutedTracks.add(idx);
    el.classList.add('muted');
  }
}

// ─── BPM ─────────────────────────────────────────────────────────────
function updateBpm() {
  bpm = parseInt(document.getElementById('bpmInput').value) || 120;
}

// ─── UPLOAD & AI CLASSIFY ────────────────────────────────────────────
function handleUpDragOver(e) {
  e.preventDefault();
  document.getElementById('uploadZone').classList.add('dragover');
}

function handleUpDragLeave() {
  document.getElementById('uploadZone').classList.remove('dragover');
}

function handleUpDrop(e) {
  e.preventDefault();
  document.getElementById('uploadZone').classList.remove('dragover');
  const files = [...e.dataTransfer.files].filter(f => f.type.startsWith('audio'));
  processFiles(files);
}

function handleFileUpload(e) {
  processFiles([...e.target.files]);
  e.target.value = '';
}

async function processFiles(files) {
  initAudio();
  for (const file of files) {
    showClassifyAnim(file.name);
    await new Promise(res => setTimeout(res, 600 + Math.random()*400));
    try {
      const buf = await file.arrayBuffer();
      const decoded = await audioCtx.decodeAudioData(buf);
      const category = classifySound(decoded);
      const sample = {
        buffer: decoded,
        category,
        name: file.name.replace(/\.[^.]+$/, ''),
        emoji: CAT_EMOJIS[category] || '🔊',
        duration: decoded.duration
      };
      loadedSamples[sample.name] = sample;
      addSampleToLibrary(sample);
      showToast(`✅ "${sample.name}" → ${CAT_LABELS[category]}`);
      // Auto-route to matching track
      const trackIdx = TRACK_DEFS.findIndex(t => t.cats.includes(category));
      if (trackIdx !== -1 && trackIdx < 5) {
        // Suggest the right track visually
        highlightTrack(trackIdx);
      }
    } catch(err) {
      showToast(`⚠️ Could not load "${file.name}"`);
    }
    hideClassifyAnim();
  }
}

function classifySound(buffer) {
  // FFT-based classification
  const data = buffer.getChannelData(0);
  const fftSize = 2048;
  const slice = data.slice(0, fftSize);

  // Compute rough spectral centroid
  const fft = new Float32Array(fftSize);
  for (let i = 0; i < fftSize; i++) fft[i] = slice[i] || 0;

  // Simple energy-in-bands approach
  const sr = buffer.sampleRate;
  const binWidth = sr / fftSize;

  let energy = { low: 0, mid: 0, high: 0 };
  let totalEnergy = 0;
  let spectralCentroid = 0;

  for (let i = 0; i < fftSize/2; i++) {
    const freq = i * binWidth;
    const amp = Math.abs(fft[i]);
    totalEnergy += amp;
    spectralCentroid += freq * amp;
    if (freq < 250) energy.low += amp;
    else if (freq < 2000) energy.mid += amp;
    else energy.high += amp;
  }

  if (totalEnergy > 0) spectralCentroid /= totalEnergy;

  // Duration-based hints
  const dur = buffer.duration;

  if (spectralCentroid < 200 && dur < 0.5) return 'kick';
  if (spectralCentroid < 500 && energy.mid > energy.low) return 'snare';
  if (spectralCentroid > 800 && energy.high > energy.low) return 'perc';
  if (spectralCentroid > 400 && spectralCentroid < 3000 && dur > 0.5) return 'vocal';
  if (dur > 1.0) return 'inst';
  return 'perc';
}

function addSampleToLibrary(sample) {
  const list = document.getElementById('samplesList');
  // Clear placeholder text
  const placeholder = list.querySelector('div[style]');
  if (placeholder) placeholder.remove();

  // Find or create category section
  let section = list.querySelector(`[data-cat="${sample.category}"]`);
  if (!section) {
    section = document.createElement('div');
    section.dataset.cat = sample.category;
    const colors = { kick:'var(--red)', snare:'var(--yellow)', vocal:'var(--accent)', perc:'var(--purple)', inst:'var(--blue)' };
    section.innerHTML = `<div class="cat-label"><span class="cat-dot" style="background:${colors[sample.category]||'#888'}"></span>${CAT_LABELS[sample.category]||sample.category}</div>`;
    list.appendChild(section);
  }

  const el = document.createElement('div');
  el.className = 'sample-item';
  el.draggable = true;
  el.innerHTML = `
    <span class="samp-emoji">${sample.emoji}</span>
    <div class="samp-info">
      <div class="samp-name">${sample.name}</div>
      <div class="samp-meta">${sample.duration.toFixed(2)}s</div>
    </div>
    <span class="samp-cat cat-${sample.category}">${CAT_LABELS[sample.category]||sample.category}</span>
  `;

  el.addEventListener('dragstart', e => {
    e.dataTransfer.setData('sampleName', sample.name);
    e.dataTransfer.effectAllowed = 'copy';
  });

  el.addEventListener('click', () => {
    initAudio();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    const src = audioCtx.createBufferSource();
    src.buffer = sample.buffer;
    src.connect(masterGain);
    src.start();
    el.classList.add('playing');
    src.onended = () => el.classList.remove('playing');
  });

  section.appendChild(el);
}

function highlightTrack(idx) {
  const row = document.querySelector(`.track-row[data-track="${idx}"]`);
  if (!row) return;
  row.style.transition = 'background 0.3s';
  row.style.background = 'rgba(93,255,143,0.06)';
  setTimeout(() => { row.style.background = ''; }, 800);
}

